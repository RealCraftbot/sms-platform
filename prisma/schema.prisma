generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  name          String?
  phone         String?
  balance       Decimal  @default(0) @db.Decimal(10, 2)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  orders        Order[]
  transactions  Transaction[]
  manualPayments ManualPayment[]
}

model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  
  reviewedPayments ManualPayment[]
}

model PaymentMethod {
  id        String   @id @default(uuid())
  name      String
  type      String
  isActive  Boolean  @default(true)
  
  orders    Order[]
}

model PricingRule {
  id          String   @id @default(uuid())
  service     String
  country     String
  basePrice   Decimal  @db.Decimal(10, 4)
  markupType  String
  markupValue Decimal  @db.Decimal(10, 4)
  finalPrice  Decimal  @db.Decimal(10, 2)
  minPrice    Decimal? @db.Decimal(10, 2)
  maxPrice    Decimal? @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  
  @@unique([service, country])
}

model Order {
  id              String   @id @default(uuid())
  userId          String
  paymentMethodId String
  type            String
  status          String
  amount          Decimal  @db.Decimal(10, 2)
  currency        String   @default("NGN")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  user            User     @relation(fields: [userId], references: [id])
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id])
  transaction     Transaction?
  manualPayment   ManualPayment?
  smsOrder        SMSOrder?
  logOrder        LogOrder?
}

model SMSOrder {
  id              String   @id @default(uuid())
  orderId         String   @unique
  service         String
  country         String
  phoneNumber     String?
  supplierOrderId String?
  smsCode         String?
  smsText         String?
  expiresAt       DateTime?
  
  order           Order    @relation(fields: [orderId], references: [id])
}

model LogCategory {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  
  logs      SocialLog[]
}

model SocialLog {
  id          String   @id @default(uuid())
  categoryId  String
  platform    String
  username    String
  email       String?
  password    String
  age         Int?
  followers   Int?
  price       Decimal  @db.Decimal(10, 2)
  costPrice   Decimal  @db.Decimal(10, 2)
  status      String   @default("available")
  soldToId    String?
  soldAt      DateTime?
  
  category    LogCategory @relation(fields: [categoryId], references: [id])
}

model LogOrder {
  id      String   @id @default(uuid())
  orderId String   @unique
  items   Json
  
  order   Order    @relation(fields: [orderId], references: [id])
}

model Transaction {
  id           String   @id @default(uuid())
  orderId      String   @unique
  userId       String
  provider     String
  providerTxId String?
  reference    String
  amount       Decimal  @db.Decimal(10, 2)
  status       String
  createdAt    DateTime @default(now())
  
  order        Order    @relation(fields: [orderId], references: [id])
  user         User     @relation(fields: [userId], references: [id])
}

model ManualPayment {
  id            String   @id @default(uuid())
  orderId       String   @unique
  userId        String
  screenshotUrl String
  notes         String?
  uploadedAt    DateTime @default(now())
  reviewedBy    String?
  reviewedAt    DateTime?
  reviewNotes   String?
  status        String   @default("pending_review")
  
  order         Order    @relation(fields: [orderId], references: [id])
  user          User     @relation(fields: [userId], references: [id])
  reviewer      Admin?   @relation(fields: [reviewedBy], references: [id])
}